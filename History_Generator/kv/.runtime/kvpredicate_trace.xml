<?xml version="1.0"?>
<!--
  Copy this file outside the repository and replace the PostgreSQL connection
  placeholders. Do not commit a password.
-->
<parameters>
    <type>POSTGRES</type>
    <driver>org.postgresql.Driver</driver>
    <url>jdbc:postgresql://127.0.0.1:5432/kvpredicate_trace_benchbase?sslmode=disable&amp;ApplicationName=benchbase-kvpredicate-ser-trace&amp;reWriteBatchedInserts=true</url>
    <username>kvpredicate_user</username>
    <password>kvpredicate_password</password>
    <reconnectOnConnectionFailure>true</reconnectOnConnectionFailure>
    <isolation>TRANSACTION_SERIALIZABLE</isolation>
    <batchsize>128</batchsize>

    <scalefactor>1</scalefactor>
    <keyCount>10</keyCount>
    <keyDist>exponential</keyDist>
    <keyDistBase>2.0</keyDistBase>
    <minTxnLength>1</minTxnLength>
    <maxTxnLength>4</maxTxnLength>
    <maxWritesPerKey>256</maxWritesPerKey>
    <predicateGroupCount>4</predicateGroupCount>
    <mopDelayMs>0</mopDelayMs>

    <!-- Set to write-skew to run the two-transaction anomaly core first. -->
    <kvPredicateAnomaly>none</kvPredicateAnomaly>
    <kvPredicateAnomalyDelayMs>250</kvPredicateAnomalyDelayMs>

    <terminals>4</terminals>
    <works>
        <work>
            <time>5</time>
            <rate>200</rate>
            <weights>100</weights>
        </work>
    </works>
    <transactiontypes>
        <transactiontype><name>Txn</name></transactiontype>
    </transactiontypes>
</parameters>
