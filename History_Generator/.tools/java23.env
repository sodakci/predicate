#!/usr/bin/env bash
# Source this file to use the project-local Java 23 installation.
_PROJECT_ROOT=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
export JAVA_HOME="$_PROJECT_ROOT/.tools/jdk-23"
export PATH="$JAVA_HOME/bin:$PATH"
export TPCC_DSN='postgresql://tpcc_user@127.0.0.1:5432/tpcc_trace'
export PGPASSFILE="$_PROJECT_ROOT/tpcc/.runtime/pgpass"
export BENCHBASE_CONFIG="$_PROJECT_ROOT/tpcc/.runtime/tpcc_trace.xml"
export BENCHBASE_HOME="$_PROJECT_ROOT/benchbase/target/benchbase-postgres/benchbase-postgres"
export BENCHBASE_JAR="$BENCHBASE_HOME/benchbase.jar"
export MAVEN_REPO_LOCAL="$_PROJECT_ROOT/benchbase/.m2"
export MAVEN_OPTS="-Dmaven.repo.local=$MAVEN_REPO_LOCAL${MAVEN_OPTS:+ $MAVEN_OPTS}"
unset _PROJECT_ROOT
